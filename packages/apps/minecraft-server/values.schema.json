{
  "title": "Chart Values",
  "type": "object",
  "properties": {
    "updateStrategy": {
      "description": "Update strategy for the Paper server version.",
      "type": "string",
      "default": "latest",
      "enum": [
        "latest",
        "auto",
        "pin",
        "build-pin"
      ]
    },
    "version": {
      "description": "Target Minecraft version. The operator requires it for the pin and build-pin strategies.",
      "type": "string",
      "default": ""
    },
    "memoryLimit": {
      "description": "Memory limit for the server container.",
      "default": "2Gi",
      "pattern": "^(\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))(([KMGTPE]i)|[numkMGTPE]|([eE](\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))))?$",
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        }
      ],
      "x-kubernetes-int-or-string": true
    },
    "cpuLimit": {
      "description": "CPU limit for the server container.",
      "default": "2000m",
      "pattern": "^(\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))(([KMGTPE]i)|[numkMGTPE]|([eE](\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))))?$",
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        }
      ],
      "x-kubernetes-int-or-string": true
    },
    "serviceType": {
      "description": "Service type used to expose the server.",
      "type": "string",
      "default": "LoadBalancer",
      "enum": [
        "LoadBalancer",
        "NodePort",
        "ClusterIP"
      ]
    },
    "backupEnabled": {
      "description": "Enable VolumeSnapshot-based backups.",
      "type": "boolean",
      "default": false
    },
    "backupSchedule": {
      "description": "Cron schedule for periodic backups.",
      "type": "string",
      "default": "0 */6 * * *"
    },
    "backupRetention": {
      "description": "Maximum number of backup snapshots to keep.",
      "type": "integer",
      "default": 10,
      "minimum": 1
    },
    "checkCron": {
      "description": "Cron schedule for checking for Paper updates.",
      "type": "string",
      "default": "0 */4 * * *"
    }
  }
}
